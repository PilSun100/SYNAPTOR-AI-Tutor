GEMINI_API_KEY=
ENVIRONMENT=development
EMBEDDING_MODEL=models/text-embedding-004
EMBEDDING_DIMENSIONS=768
DATABASE_URL=postgresql+psycopg://synaptor:synaptor_password@localhost:5432/synaptor
# Local-only fallback for quick tests:
# DATABASE_URL=sqlite:///./data/synaptor.db
UPLOAD_DIR=./data/uploads
MAX_UPLOAD_MB=20
CORS_ORIGINS=http://localhost:5173
# Production에서는 32자 이상의 고유한 값으로 반드시 교체하세요.
JWT_SECRET_KEY=change-this-development-secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14
AUTO_CREATE_TABLES=false
VITE_API_BASE_URL=http://localhost:8000/api
